# Host ports
HYPERBOARD_WEB_PORT=8080
HYPERBOARD_STORAGE_PORT=9000

# Data storage directories - customize these paths for your deployment
HYPERBOARD_POSTGRESQL_DATA_DIR=/var/lib/hyperboard/postgresql
HYPERBOARD_RUSTFS_DATA_DIR=/var/lib/hyperboard/rustfs

# Database credentials
HYPERBOARD_DB_USER=hyperboard
HYPERBOARD_DB_PASSWORD=hyperboard  # change this
HYPERBOARD_DB_NAME=hyperboard

# S3-compatible storage credentials
HYPERBOARD_STORAGE_ACCESS_KEY=rustfsadmin  # change this
HYPERBOARD_STORAGE_SECRET_KEY=rustfsadmin  # change this
HYPERBOARD_STORAGE_BUCKET=hyperboard
HYPERBOARD_STORAGE_REGION=us-east-1

# Admin password (shared between API and web)
HYPERBOARD_ADMIN_PASSWORD=hyperboard  # change this

# Session secret key for signing web session cookies
HYPERBOARD_SESSION_SECRET=hyperboard  # change this
