[Unit]
Description=Hyperboard API
After=hyperboard-postgresql.service hyperboard-rustfs.service
Requires=hyperboard-postgresql.service hyperboard-rustfs.service

[Container]
Image=ghcr.io/dharmab/hyperboard-api:main
ContainerName=hyperboard-api
Network=hyperboard.network
Environment=HYPERBOARD_API_POSTGRESQL_HOST=hyperboard-postgresql
Environment=HYPERBOARD_API_POSTGRESQL_USER=${HYPERBOARD_DB_USER}
Environment=HYPERBOARD_API_POSTGRESQL_PASSWORD=${HYPERBOARD_DB_PASSWORD}
Environment=HYPERBOARD_API_POSTGRESQL_DATABASE=${HYPERBOARD_DB_NAME}
Environment=HYPERBOARD_API_POSTGRESQL_SSL_MODE=disable
Environment=HYPERBOARD_API_ADMIN_PASSWORD=${HYPERBOARD_ADMIN_PASSWORD}
Environment=HYPERBOARD_API_STORAGE_ENDPOINT=http://hyperboard-rustfs:9000
Environment=HYPERBOARD_API_STORAGE_BUCKET=${HYPERBOARD_STORAGE_BUCKET}
Environment=HYPERBOARD_API_STORAGE_ACCESS_KEY=${HYPERBOARD_STORAGE_ACCESS_KEY}
Environment=HYPERBOARD_API_STORAGE_SECRET_KEY=${HYPERBOARD_STORAGE_SECRET_KEY}
Environment=HYPERBOARD_API_STORAGE_REGION=${HYPERBOARD_STORAGE_REGION}
Environment=HYPERBOARD_API_STORAGE_USE_PATH_STYLE=true
Environment=HYPERBOARD_API_LOG_LEVEL=info
PublishPort=8081:8080
HealthCmd=curl -f http://localhost:8080/healthz || exit 1
HealthInterval=5s
HealthTimeout=3s
HealthRetries=5

[Service]
EnvironmentFile=/etc/hyperboard/hyperboard.env
Restart=always

[Install]
WantedBy=multi-user.target default.target
