FROM --platform=${BUILDPLATFORM} golang:1.26 AS builder

ARG BUILDPLATFORM
ARG TARGETOS=linux
ARG TARGETARCH=amd64

WORKDIR /app

COPY go.mod go.sum ./

RUN --mount=type=cache,target=/go/pkg/mod \
    go mod download -x

COPY cmd/ cmd/
COPY internal/ internal/
COPY pkg/ pkg/

RUN --mount=type=cache,target=/go/pkg/mod \
    --mount=type=cache,target=/root/.cache/go-build \
    CGO_ENABLED=0 GOOS=${TARGETOS} GOARCH=${TARGETARCH} go build -o /bin/hyperboard-api ./cmd/hyperboard-api

RUN --mount=type=cache,target=/go/pkg/mod \
    --mount=type=cache,target=/root/.cache/go-build \
    CGO_ENABLED=0 GOOS=${TARGETOS} GOARCH=${TARGETARCH} go build -o /bin/hyperboard-web ./cmd/hyperboard-web

RUN --mount=type=cache,target=/go/pkg/mod \
    --mount=type=cache,target=/root/.cache/go-build \
    CGO_ENABLED=0 GOOS=${TARGETOS} GOARCH=${TARGETARCH} go build -o /bin/hyperboardctl ./cmd/hyperboardctl

FROM debian:13-slim AS hyperboard-api
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
      ca-certificates \
      webp \
      ffmpeg \
    && rm -rf /var/lib/apt/lists/*
COPY --from=builder /bin/hyperboard-api /hyperboard-api
ENTRYPOINT ["/hyperboard-api"]

FROM gcr.io/distroless/static-debian12:debug AS hyperboard-web
COPY --from=builder /bin/hyperboard-web /hyperboard-web
ENTRYPOINT ["/hyperboard-web"]

FROM scratch AS hyperboardctl
COPY --from=builder /bin/hyperboardctl /hyperboardctl
ENTRYPOINT ["/hyperboardctl"]
